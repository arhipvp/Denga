NODE_ENV=development
PORT=3001
WEB_PORT=3000
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001
CORS_ALLOWED_ORIGINS=
# Required for the Next.js admin panel. Without it the app renders a configuration error instead of the dashboard.
NEXT_PUBLIC_API_URL=http://localhost:3001/api
DATABASE_URL=postgresql://denga:denga@localhost:5433/denga?schema=public
POSTGRES_PORT=5433
JWT_SECRET=change-me
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now
VERIFY_MEMBER_EMAIL=
VERIFY_MEMBER_PASSWORD=
HOUSEHOLD_NAME=Моя семья
DEFAULT_CURRENCY=EUR
TELEGRAM_BOT_TOKEN=
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_POLLING_ENABLED=true
POLZA_API_KEY=
POLZA_BASE_URL=https://polza.ai/api/v1
POLZA_MODEL=google/gemini-2.5-flash
UPLOAD_DIR=uploads
BACKUP_DIR=backups
BACKUP_KEEP_COUNT=10
LOG_DIR=logs
LOG_LEVEL=info
CLARIFICATION_TIMEOUT_MINUTES=30
