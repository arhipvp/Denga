{
  "name": "denga",
  "version": "0.1.0",
  "private": true,
  "description": "Family finance tracker with Telegram bot ingestion and AI-powered receipt parsing.",
  "license": "MIT",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @denga/shared && npm run build --workspace @denga/web",
    "clean": "node scripts/clean.mjs",
    "dev": "python -m uvicorn app.main:app --app-dir apps/python_backend --host 0.0.0.0 --port 3001",
    "dev:api": "python -m uvicorn app.main:app --app-dir apps/python_backend --host 0.0.0.0 --port 3001",
    "dev:web": "npm run dev --workspace @denga/web",
    "test": "npm run test --workspace @denga/shared && npm run test --workspace @denga/web",
    "lint": "npm run lint --workspace @denga/web",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "overrides": {
    "test-exclude": "8.0.0"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "@prisma/client": "^6.18.0",
    "axios": "^1.14.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "next": "^16.2.1",
    "openai": "^6.33.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "telegraf": "^4.16.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@swc/core": "^1.15.24",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "jest": "^30.3.0",
    "prisma": "^6.18.0",
    "typescript": "^5.9.3"
  }
}
