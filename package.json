{
  "name": "denga",
  "version": "0.1.0",
  "private": true,
  "description": "Family finance tracker with Telegram bot ingestion and AI-powered receipt parsing.",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @denga/shared && npm run build --workspace @denga/api && npm run build --workspace @denga/web",
    "dev": "npm run dev --workspace @denga/api",
    "dev:api": "npm run dev --workspace @denga/api",
    "dev:web": "npm run dev --workspace @denga/web",
    "test": "npm run test --workspace @denga/api && npm run test --workspace @denga/shared && npm run test --workspace @denga/web",
    "lint": "npm run lint --workspace @denga/web",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.4",
    "@prisma/client": "^6.18.0",
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "clsx": "^2.1.1",
    "cron": "^4.4.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "next": "^16.2.1",
    "openai": "^6.33.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "telegraf": "^4.16.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.17",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "jest": "^30.3.0",
    "prisma": "^6.18.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
