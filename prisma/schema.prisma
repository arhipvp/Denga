generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  CONFIRMED
  NEEDS_CLARIFICATION
  CANCELLED
}

enum SourceMessageType {
  TELEGRAM_TEXT
  TELEGRAM_RECEIPT
  ADMIN_MANUAL
}

enum SourceMessageStatus {
  RECEIVED
  PENDING_REVIEW
  PARSED
  NEEDS_CLARIFICATION
  CANCELLED
  ERROR
}

enum ClarificationStatus {
  OPEN
  RESOLVED
  CANCELLED
  EXPIRED
}

enum AiParseAttemptType {
  INITIAL_PARSE
  CLARIFICATION_REPARSE
}

model Household {
  id              String          @id @default(cuid())
  name            String
  defaultCurrency String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  users           User[]
  categories      Category[]
  transactions    Transaction[]
  sourceMessages  SourceMessage[]
  settings        AppSetting[]
}

model User {
  id               String           @id @default(cuid())
  householdId      String
  email            String?          @unique
  passwordHash     String?
  displayName      String
  role             UserRole         @default(MEMBER)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  household        Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  telegramAccounts TelegramAccount[]
  transactions     Transaction[]    @relation("TransactionAuthor")
  sourceMessages   SourceMessage[]  @relation("SourceMessageAuthor")
  reviewDrafts     PendingOperationReview[]
}

model TelegramAccount {
  id           String   @id @default(cuid())
  userId       String
  telegramId   String   @unique
  username     String?
  firstName    String?
  lastName     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id          String        @id @default(cuid())
  householdId String
  name        String
  type        CategoryType   @default(EXPENSE)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([householdId, name])
}

model Transaction {
  id              String             @id @default(cuid())
  householdId     String
  authorId        String?
  categoryId      String?
  sourceMessageId String?            @unique
  type            TransactionType
  amount          Decimal            @db.Decimal(12, 2)
  currency        String
  occurredAt      DateTime
  comment         String?
  status          TransactionStatus  @default(CONFIRMED)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  household       Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  author          User?              @relation("TransactionAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  category        Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  sourceMessage   SourceMessage?     @relation(fields: [sourceMessageId], references: [id], onDelete: SetNull)
}

model SourceMessage {
  id                   String               @id @default(cuid())
  householdId          String
  authorId             String?
  telegramMessageId    String?              @unique
  telegramChatId       String?
  type                 SourceMessageType
  status               SourceMessageStatus  @default(RECEIVED)
  text                 String?
  rawPayload           Json
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  household            Household            @relation(fields: [householdId], references: [id], onDelete: Cascade)
  author               User?                @relation("SourceMessageAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  attachments          Attachment[]
  transaction          Transaction?
  parseAttempts        AiParseAttempt[]
  clarificationSession ClarificationSession?
  reviewDraft          PendingOperationReview?
}

model Attachment {
  id              String        @id @default(cuid())
  sourceMessageId String
  telegramFileId  String?
  telegramFilePath String?
  mimeType        String?
  originalName    String?
  localPath       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  sourceMessage   SourceMessage @relation(fields: [sourceMessageId], references: [id], onDelete: Cascade)
}

model AiParseAttempt {
  id              String        @id @default(cuid())
  sourceMessageId String
  attemptType     AiParseAttemptType @default(INITIAL_PARSE)
  provider        String
  model           String
  prompt          String
  responsePayload Json
  success         Boolean
  createdAt       DateTime      @default(now())
  sourceMessage   SourceMessage @relation(fields: [sourceMessageId], references: [id], onDelete: Cascade)
}

model ClarificationSession {
  id              String              @id @default(cuid())
  sourceMessageId String              @unique
  status          ClarificationStatus @default(OPEN)
  question        String
  answer          String?
  conversation    Json?
  expiresAt       DateTime
  resolvedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  sourceMessage   SourceMessage       @relation(fields: [sourceMessageId], references: [id], onDelete: Cascade)
}

model PendingOperationReview {
  id                String              @id @default(cuid())
  sourceMessageId   String              @unique
  authorId          String?
  status            SourceMessageStatus @default(PENDING_REVIEW)
  draft             Json
  pendingField      String?
  lastBotMessageId  String?
  activePickerMessageId String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  sourceMessage     SourceMessage       @relation(fields: [sourceMessageId], references: [id], onDelete: Cascade)
  author            User?               @relation(fields: [authorId], references: [id], onDelete: SetNull)
}

model AppSetting {
  id          String    @id @default(cuid())
  householdId String
  key         String
  value       String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([householdId, key])
}
